scalar DateTime

type Query {
  measurements(startTime: DateTime!, endTime: DateTime): [Measurement!]!
  latest: [Measurement!]!
}

type Measurement {
  deviceId: String!
  timestamp: DateTime!
  uploadTimestamp: DateTime!

  temp: Float
  pm1: Float
  pm25: Float
  pm4: Float
  pm10: Float
  aqi: Float
  rh: Float
  vocIndex: Float
  noxIndex: Float
  hcho: Float
  co2: Float
}
